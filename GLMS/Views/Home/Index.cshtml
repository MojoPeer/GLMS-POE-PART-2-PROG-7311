@{
    ViewData["Title"] = "Home";
}

<div class="text-center mt-5">
    <h1 class="display-4 fw-bold">Global Logistics Management System</h1>
    <p class="lead text-muted">Manage Clients, Contracts, and Service Requests efficiently.</p>
</div>

<div class="row mt-5 text-center">

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h4>Clients</h4>
                <p>Manage all logistics clients and their information.</p>
                <a asp-controller="Clients" asp-action="Index" class="btn btn-primary">View Clients</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h4>Contracts</h4>
                <p>Create and manage contracts with PDF agreements.</p>
                <a asp-controller="Contracts" asp-action="Index" class="btn btn-success">View Contracts</a>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card shadow-sm">
            <div class="card-body">
                <h4>Service Requests</h4>
                <p>Track logistics service requests with currency conversion.</p>
                <a asp-controller="ServiceRequests" asp-action="Index" class="btn btn-warning text-dark">View Requests</a>
            </div>
        </div>
    </div>

</div>