@model GLMS.Models.Client

<h2>Client Details</h2>
<div>
    <strong>Name:</strong> @Model.Name
</div>
<div>
    <strong>Contact:</strong> @Model.ContactDetails
</div>
<div>
    <strong>Region:</strong> @Model.Region
</div>
<div>
    <h3>Contracts</h3>
    <ul>
    @foreach(var c in Model.Contracts)
    {
        <li>@c.ServiceLevel - @c.Status</li>
    }
    </ul>
</div>
<p><a href="/Clients">Back to list</a></p>
