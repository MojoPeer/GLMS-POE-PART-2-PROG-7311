@model GLMS.Models.Client

<h2>Create Client</h2>
<form asp-action="Create" method="post">
    <div>
        <label asp-for="Name"></label>
        <input asp-for="Name" />
    </div>
    <div>
        <label asp-for="ContactDetails"></label>
        <input asp-for="ContactDetails" />
    </div>
    <div>
        <label asp-for="Region"></label>
        <input asp-for="Region" />
    </div>
    <button type="submit">Create</button>
</form>
